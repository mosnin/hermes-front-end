# ---------------------------------------------------------------------------
# Hermes Control Plane — environment variables
# Copy to .env.local and fill in. (.env.local is gitignored.)
# ---------------------------------------------------------------------------

# --- Convex ---------------------------------------------------------------
# Created automatically when you run `npx convex dev` the first time.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# --- Clerk ----------------------------------------------------------------
# From the Clerk dashboard (https://dashboard.clerk.com) → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk sends users for auth (defaults work with the app's routes).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---------------------------------------------------------------------------
# The following are set in the CONVEX deployment environment, not here.
# Run, e.g.:  npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-clerk-domain
# ---------------------------------------------------------------------------
#   CLERK_JWT_ISSUER_DOMAIN   Issuer of the Clerk "convex" JWT template
#   OPENAI_API_KEY            (optional) enables embeddings + vector search
#   COMPOSIO_API_KEY          (optional) enables integrations (OAuth/tools/triggers)
#   COMPOSIO_BASE_URL         (optional) override Composio API base
#   COMPOSIO_WEBHOOK_SECRET   (optional) verifies inbound Composio trigger webhooks
#   Composio trigger webhook URL: https://<deployment>.convex.site/integrations/composio/webhook
